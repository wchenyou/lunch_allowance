ADMIN_PASSWORD=change-this-admin-password

# Supabase project values. Required for the new database, auth, and receipt
# image storage path. Do not expose SUPABASE_SERVICE_ROLE_KEY to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=
RECEIPT_IMAGE_BUCKET=receipt-images

# Optional. When all Google variables are present, the app uses Google Sheets.
# Without them, API routes fall back to data/local-db.json for local development.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional comma-separated list of employee names seeded when storage is empty.
SEED_EMPLOYEES=Aaron
